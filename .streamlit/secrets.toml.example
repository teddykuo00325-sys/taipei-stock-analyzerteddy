# 複製此檔為 secrets.toml 並填入實際值（secrets.toml 已在 .gitignore，不會推到 GitHub）

# === Telegram Bot ===
# Bot Token: 找 @BotFather → /newbot
# Chat ID:   跟 Bot 私訊 /start，然後打開
#            https://api.telegram.org/bot<TOKEN>/getUpdates
#            找 "chat":{"id": ...} 那串數字
#
# 支援的 chat_id 格式：
#   - 單一私訊：   chat_id = "5506547630"
#   - 多個收件人：  chat_id = "5506547630,-1001234567890,@teddy_stockreport"
#   - List 寫法：   chat_id = ["5506547630", "-1001234567890"]
#   - 公開頻道：   chat_id = "@teddy_stockreport"  (記得把 Bot 加為 Channel admin)
[telegram]
bot_token = "PASTE_YOUR_BOT_TOKEN_HERE"
chat_id   = "PASTE_YOUR_CHAT_ID_HERE"

# === GitHub Backup (Streamlit Cloud 部署時的雲端持久化) ===
# Personal Access Token: github.com → Settings → Developer settings → PAT
#                        需 repo 寫入權限
# owner / repo: 你的 GitHub 帳號 + 私 fork 的這個專案 repo
[github]
token    = "ghp_PASTE_YOUR_PAT_HERE"
owner    = "YOUR_GITHUB_USERNAME"
repo     = "YOUR_REPO_NAME"
branch   = "main"
db_path  = "data/etf.db"
